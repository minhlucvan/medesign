  echo "                   ├─ Sync          Reconcile delta vs canonical specs"
  echo "                   ├─ Changelog     Prepend Keep a Changelog entry"
  echo "                   └─ Finalize      Push + gh pr create"
  echo "  ship            ship-plan + ship-code in one command"
  echo "  address-review  Fix PR feedback → re-verify gates → push → reply → human re-reviews"
  echo "  merge-pr        Auto-dispatch: spec/ branch → merge-pr-spec, feat/ → merge-pr-code"
  echo "  author-review   Automated multi-dimension code review (for team leads)"
  echo ""

  # ─── EXTENSIONS ─────────────────────────────────────────────────────
  printf "${B}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
