    printf "${B}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
    echo ""
    echo "  before-spec            🟢 Comment \"Spec started\" on linked issue"
    echo "  after-spec-pr-opened   📋 Status → in-review, record PR ref, assign @me"
    echo "  after-spec-pr-merged   ✅ Record merge SHA"
    echo "  before-ship            🚀 Comment \"Implementation starting\""
    echo "  after-code-pr-opened   🔧 Status → in-review, assign @me, record PR + changelog"
    echo "  after-review-addressed 💬 Comment \"Review feedback addressed\""
    echo "  after-code-pr-merged   🎉 Status → done, close issue, archive change"
