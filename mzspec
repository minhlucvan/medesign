  printf "${B}  CORE PIPELINE${NC}\n"
  printf "${B}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
  echo ""
  echo "  ┌─────────┐   ┌──────┐   ┌─────────┐   ┌───────────┐   ┌──────────┐   ┌───────────┐"
  echo "  │ PROPOSE │──→│ SPEC │──→│ SPEC-PR │──→│ ⚠️  MERGE │──→│SHIP-PLAN │──→│ SHIP-CODE │"
  echo "  └─────────┘   └──────┘   └─────────┘   │ (HUMAN)  │   └──────────┘   └───────────┘"
  echo "                                          └──────────┘         │              │"
  echo "                                                                           ▼"
  echo "                                                       ┌───────────┐   ┌───────────┐"
  echo "                                                       │ SHIP-CODE │──→│ ⚠️  MERGE │──→ 🎉"
  echo "                                                       │ (cont.)   │   │ (HUMAN)   │"
  echo "                                                       └───────────┘   └───────────┘"
  echo ""

  # ─── COMMANDS ───────────────────────────────────────────────────────
  printf "${B}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
  printf "${B}  COMMANDS${NC}\n"
  printf "${B}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
  echo ""
  echo "  propose        Scaffold a change from a prompt → cNNNN-<slug>/ with proposal,"
  echo "                 design.md, tasks.md, delta specs"
  echo "  spec           Cross-validate spec across 6 axes → review/REVIEW.md"
  echo "  spec-pr        Sync delta→canonical specs, open spec-only PR → [HUMAN MERGES]"
  echo "  ship-plan      Group tasks into 1-4 TDD work-units → .handoff/<change>/"
  echo "  ship-code      Execute units: Red→Green→commit → Verify → Review → Evidence → PR"
  echo "                   ├─ Base sync     Fetch + ff-merge base branch"
  echo "                   ├─ Preflight     Tools check, validate, branch, load handoff"
  echo "                   ├─ Implement     Per unit: Red (failing test) → Green (code) → commit"
