}

# ---- install / update (delegate to bash scripts) ----------------------------
cmd_install() {
  if [ "$REPO_MODE" -eq 1 ]; then
    exec bash "$MZSPEC_DIR/scripts/install.sh" "$@"
  else
    # Vendored mode: download from GitHub
    local ref="main"
    local args=()
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --ref) ref="${2:?}"; shift 2 ;;
        --ref=*) ref="${1#*=}"; shift ;;
        *) args+=("$1"); shift ;;
      esac
    done
    log "fetching install.sh@$ref from GitHub ..."
    bash <(curl -fsSL "https://raw.githubusercontent.com/minhlucncc/mzspec/$ref/scripts/install.sh") "${args[@]}"
  fi
}

cmd_update() {
  if [ "$REPO_MODE" -eq 1 ]; then
    exec bash "$MZSPEC_DIR/scripts/update.sh" "$@"
  else
    local ref="main"
    local args=()
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --ref) ref="${2:?}"; shift 2 ;;
        --ref=*) ref="${1#*=}"; shift ;;
        *) args+=("$1"); shift ;;
      esac
    done
    log "fetching update.sh@$ref from GitHub ..."
    bash <(curl -fsSL "https://raw.githubusercontent.com/minhlucncc/mzspec/$ref/scripts/update.sh") "${args[@]}"
  fi
}

# ---- main dispatch ----------------------------------------------------------
[ "$#" -eq 0 ] && usage

case "$1" in
  help|-h|--help)
    usage
    ;;
  version|-v|--version)
    version
    ;;
  install)
    shift; cmd_install "$@"
    ;;
  update)
    shift; cmd_update "$@"
    ;;
  ext)
    shift
    [ "$#" -eq 0 ] && { echo "usage: mzspec ext <add|remove|list|info> ..."; exit 1; }
    case "$1" in
      add)      shift; [ -z "${1:-}" ] && { echo "usage: mzspec ext add <extension> [--force]"; exit 1; }; ext_cmd_add "$@" ;;
      remove)   shift; [ -z "${1:-}" ] && { echo "usage: mzspec ext remove <extension>"; exit 1; }; ext_cmd_remove "$@" ;;
      list)     shift; case "${1:-}" in --available|--all) ext_list_available; shift;; --installed) ext_list_installed; shift;; *) ext_list_available;; esac ;;
      info)     shift; [ -z "${1:-}" ] && { echo "usage: mzspec ext info <extension>"; exit 1; }; ext_cmd_info "$@" ;;
      *)        echo "unknown ext subcommand: $1 (try add, remove, list, info)"; exit 1 ;;
    esac
    ;;
  spec)
    shift; node_dispatch "openspec" "$@"
    ;;
  gate-resolver)
    shift; node_dispatch "gate-resolver" "$@"
    ;;
  discover)
    shift; node_dispatch "discover" "$@"
    ;;
  template)
    shift; node_dispatch "templates" "$@"
    ;;
  hooks)
    shift
    [ "$#" -eq 0 ] && { echo "usage: mzspec hooks list [--all]"; exit 1; }
    case "$1" in
      list) shift; hooks_list "$@" ;;
      *)    echo "unknown hooks subcommand: $1 (try list)"; exit 1 ;;
    esac
    ;;
  docs)
    docs_cmd
    ;;
  list)
    warn "'./mzspec list' is deprecated. Use './mzspec ext list --available' instead."
    ext_list_available
    ;;
  info)
    warn "'./mzspec info' is deprecated. Use './mzspec ext info <name>' instead."
    shift; [ -z "${1:-}" ] && { echo "usage: mzspec info <extension>"; exit 1; }; ext_cmd_info "$@"
    ;;
  *)
    if [ -n "${1:-}" ]; then
      # Check if it looks like an old-style ext install (first arg is an extension name)
      if [ -n "$EXTENSIONS_DIR" ] && [ -d "$EXTENSIONS_DIR/${1:-}" ]; then
        warn "'./mzspec $1' is deprecated. Use './mzspec ext add $1' instead."
        ext_cmd_add "$@"
      else
        die "unknown command: $1 (try './mzspec help')"
      fi
    else
      usage
    fi
    ;;
esac
